# NetBox environment - testomgeving (wijzig SECRET_KEY in productie!)
# Vereist voor v2 API tokens (o.a. Discovery/Diode)
API_TOKEN_PEPPER_1=dev-pepper-change-in-production-use-random-50chars
ALLOWED_HOSTS=*
CORS_ORIGIN_ALLOW_ALL=True
DB_HOST=postgres
DB_NAME=netbox
DB_PASSWORD=netbox_dev_pass
DB_USER=netbox
EMAIL_FROM=netbox@localhost
GRAPHQL_ENABLED=true
MEDIA_ROOT=/opt/netbox/netbox/media
REDIS_CACHE_DATABASE=1
REDIS_CACHE_HOST=redis-cache
REDIS_CACHE_PASSWORD=redis_cache_pass
REDIS_CACHE_SSL=false
REDIS_DATABASE=0
REDIS_HOST=redis
REDIS_PASSWORD=redis_pass
REDIS_SSL=false
SECRET_KEY=change-me-in-production-use-at-least-50-chars-random-string-here
WEBHOOKS_ENABLED=true

# Maak automatisch een superuser aan bij de eerste start
SUPERUSER_NAME=admin
SUPERUSER_PASSWORD=admin
SUPERUSER_EMAIL=admin@example.com
